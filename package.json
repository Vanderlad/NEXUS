{
  "name": "nexus",
  "version": "0.1.0",
  "description": "NEXUS — a local-first, gamified second-brain command center for CS students",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,ui -c cyan,magenta \"node server/index.js\" \"vite\"",
    "server": "node server/index.js",
    "build": "vite build",
    "start": "npm run build && node server/index.js",
    "demo": "node server/demo.js",
    "demo:reset": "node server/demo.js --reset"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "dompurify": "^3.1.6",
    "express": "^4.19.2",
    "marked": "^12.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "vite": "^5.4.8"
  }
}
